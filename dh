local ic = UIS.InputBegan:Connect(function(inp, gp)
    if gp then return end

    -- Toggle HUB visibility
    if inp.KeyCode == Enum.KeyCode.M and UIReady then
        local v = not MF.Visible; MF.Visible = v; Glow.Visible = v
    end

    -- ── AIMBOT  [ Q ]  ─────────────────────────────────────────
    -- SIN notificación al usar la key, solo al pulsar el pill ON/OFF
    if inp.KeyCode == Enum.KeyCode.Q and T.aimbot and not locking then
        locking = true
        local best, bestD = nil, math.huge
        local ctr = cam.ViewportSize / 2
        for _, p in pairs(PLS:GetPlayers()) do
            if p ~= lp and p.Character then
                local head = p.Character:FindFirstChild("Head")
                if head then
                    local pos2D, onScreen = cam:WorldToViewportPoint(head.Position)
                    if onScreen and pos2D.Z > 0 then
                        local d = (Vector2.new(pos2D.X, pos2D.Y) - ctr).Magnitude
                        if d < bestD and d < SL.aimbotDist then bestD = d; best = head end
                    end
                end
            end
        end
        if best then
            local st = tick(); local c2
            c2 = RS.RenderStepped:Connect(function()
                if tick() - st >= lockTime or not T.aimbot or not best or not best.Parent then
                    c2:Disconnect(); locking = false; return
                end
                cam.CFrame = CFrame.new(cam.CFrame.Position, best.Position)
            end)
        else
            locking = false
            -- Solo aviso si no hay target (esto es util, no es el toggle)
            notifyWarn("Aimbot: no target in range", "AIMBOT")
        end
    end

    -- ── TELEPORT TO CURSOR  [ Z ]  ─────────────────────────────
    -- SIN notificación al teletransportarse (solo al activar/desactivar el toggle)
    if inp.KeyCode == Enum.KeyCode.Z and T.teleport then
        local hrp = getHRP()
        if hrp then
            local mouse = lp:GetMouse()
            local targetPos = mouse.Hit.Position + Vector3.new(0, 3, 0)
            hrp.CFrame = CFrame.new(targetPos)
            -- Sin notificación aquí
        end
    end
end)
table.insert(conns, ic)

-- ================================================================
--  RENDERSTEPPED  —  continuous logic
-- ================================================================
local rsConn = RS.RenderStepped:Connect(function()
    local char = getChar(); if not char then return end
    local hrp  = char:FindFirstChild("HumanoidRootPart")
    local hum  = char:FindFirstChild("Humanoid")

    -- Speed / Jump
    if T.speed   and hum then hum.WalkSpeed  = SL.walkSpeed  end
    if T.infJump and hum then hum.JumpPower  = SL.jumpPower  end

    -- Infinite Jump (space detection)
    if T.infJump and UIS:IsKeyDown(Enum.KeyCode.Space) then
        if hum then hum:ChangeState(Enum.HumanoidStateType.Jumping) end
    end

    -- No Clip
    if T.noclip then
        for _, p in pairs(char:GetDescendants()) do
            if p:IsA("BasePart") then pcall(function() p.CanCollide = false end) end
        end
    end

    -- ── ESP Box ────────────────────────────────────────────────
    for _, p in pairs(PLS:GetPlayers()) do
        if p == lp then continue end

        if not T.espBox then
            if espBoxObj[p] then
                pcall(function()
                    if espBoxObj[p].box   then espBoxObj[p].box.Visible   = false end
                    if espBoxObj[p].nameL then espBoxObj[p].nameL.Visible = false end
                end)
                espBoxObj[p] = nil
            end
            continue
        end

        if not p.Character or not p.Character:FindFirstChild("HumanoidRootPart") then
            if espBoxObj[p] then
                pcall(function()
                    if espBoxObj[p].box   then espBoxObj[p].box.Visible   = false end
                    if espBoxObj[p].nameL then espBoxObj[p].nameL.Visible = false end
                end)
                espBoxObj[p] = nil
            end
            continue
        end

        if not espBoxObj[p] then
            local ok1, box   = pcall(function() return Drawing.new("Square") end)
            local ok2, nameL = pcall(function() return Drawing.new("Text")   end)
            espBoxObj[p] = {
                box   = ok1 and box   or nil,
                nameL = ok2 and nameL or nil,
            }
            if ok1 then
                box.Thickness = 1.5
                box.Color     = Color3.fromRGB(220, 50, 50)
                box.Filled    = false
                box.Visible   = false
            end
            if ok2 then
                nameL.Size    = 13
                nameL.Color   = Color3.fromRGB(255, 160, 160)
                nameL.Outline = true
                nameL.Text    = p.Name
                nameL.Visible = false
            end
        end

        local head = p.Character:FindFirstChild("Head")
        if not head then continue end

        local pos2D, onScreen = cam:WorldToViewportPoint(head.Position)

        if onScreen and pos2D.Z > 0 then
            local dist = (cam.CFrame.Position - head.Position).Magnitude
            local sc   = math.clamp(1600 / dist, 14, 120)
            local bx   = pos2D.X - sc * 0.5
            local by   = pos2D.Y - sc * 0.8

            if espBoxObj[p].box then
                espBoxObj[p].box.Position = Vector2.new(bx, by)
                espBoxObj[p].box.Size     = Vector2.new(sc, sc * 2)
                espBoxObj[p].box.Visible  = true
            end
            if espBoxObj[p].nameL then
                espBoxObj[p].nameL.Position = Vector2.new(bx, by - 18)
                espBoxObj[p].nameL.Visible  = true
            end
        else
            if espBoxObj[p].box   then espBoxObj[p].box.Visible   = false end
            if espBoxObj[p].nameL then espBoxObj[p].nameL.Visible = false end
        end
    end
end)
table.insert(conns, rsConn)

