local particleConns={}
local function spawnSnowflake(canvas)
    local dot=Instance.new("Frame",canvas)
    local sz=math.random(2,4); dot.Size=UDim2.new(0,sz,0,sz)
    local canW=canvas.AbsoluteSize.X>0 and canvas.AbsoluteSize.X or 522
    local canH=canvas.AbsoluteSize.Y>0 and canvas.AbsoluteSize.Y or 404
    local cx=math.random(0,math.floor(canW)); local cy=0
    dot.Position=UDim2.new(0,cx,0,cy)
    dot.BackgroundColor3=C.red1; dot.BackgroundTransparency=math.random(40,60)/100
    dot.BorderSizePixel=0; dot.ZIndex=2; Instance.new("UICorner",dot).CornerRadius=UDim.new(1,0)
    local vy=math.random(25,60); local vx=math.random(-12,5)
    local wobble=math.random(0,100)/100; local wobbleA=math.random(6,18); local wobbleF=math.random(8,16)/10
    local life=0; local maxLife=(canH/vy)*math.random(90,110)/100
    local conn
    conn=RS.Heartbeat:Connect(function(dt)
        if not dot.Parent then conn:Disconnect(); return end
        life=life+dt; cx=cx+vx*dt+math.sin((life+wobble)*wobbleF)*wobbleA*dt; cy=cy+vy*dt
        dot.Position=UDim2.new(0,cx,0,cy)
        local prog=life/maxLife
        if prog>=0.6 then dot.BackgroundTransparency=math.min(1,(prog-0.6)/0.4) end
        if cy>canH+8 or cx<-20 or cx>canW+20 or life>=maxLife then conn:Disconnect(); pcall(function() dot:Destroy() end) end
    end)
    table.insert(particleConns,conn)
end

local function spawnShootingStar(canvas)
    local star=Instance.new("Frame",canvas)
    local len=math.random(20,48); star.Size=UDim2.new(0,len,0,2)
    local canW=canvas.AbsoluteSize.X>0 and canvas.AbsoluteSize.X or 522
    local canH=canvas.AbsoluteSize.Y>0 and canvas.AbsoluteSize.Y or 404
    local margin=30
    local cx=math.random(margin,math.max(margin+1,math.floor(canW)-margin))
    local cy=math.random(margin,math.max(margin+1,math.floor(canH*0.5)))
    star.Position=UDim2.new(0,cx,0,cy)
    star.BackgroundColor3=Color3.fromRGB(255,140,140); star.BackgroundTransparency=0.1
    star.BorderSizePixel=0; star.ZIndex=2
    local angle=math.random(20,50); star.Rotation=angle
    Instance.new("UICorner",star).CornerRadius=UDim.new(1,0)
    local grad=Instance.new("UIGradient",star)
    grad.Transparency=NumberSequence.new{NumberSequenceKeypoint.new(0,0),NumberSequenceKeypoint.new(0.55,0.25),NumberSequenceKeypoint.new(1,1)}
    local rad=math.rad(angle); local spd=math.random(200,380)
    local dx=math.cos(rad)*spd; local dy=math.sin(rad)*spd
    local life=0; local maxLife=math.min(math.random(5,9)/10,(canW*0.5)/spd)
    local conn
    conn=RS.Heartbeat:Connect(function(dt)
        if not star.Parent then conn:Disconnect(); return end
        life=life+dt; cx=cx+dx*dt; cy=cy+dy*dt
        if cx<0 or cx>canW or cy<0 or cy>canH or life>=maxLife then conn:Disconnect(); pcall(function() star:Destroy() end); return end
        star.Position=UDim2.new(0,cx,0,cy)
        star.BackgroundTransparency=math.min(1,life/maxLife)
    end)
    table.insert(particleConns,conn)
end

