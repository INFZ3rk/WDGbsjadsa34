-- Key validation logic
local function tryKey()
    local input=KBox.Text
    if input=="" then KErr.Text="  Please enter a key."; return end
    keyAttempts=keyAttempts+1
    KAtt.Text="Attempts: "..keyAttempts.." / "..MAX_ATTEMPTS
    local valid, result = isValidKey(input)
    if valid then
        -- Bind key to this userId in _G so it can't be reused by another account this session
        _G.__WDGKeyOwners[result] = lp.UserId
        usedKey   = result   -- save for startup log
        keyPassed = true
        KErr.Text=""; KErr.TextColor3=C.green
        KBtn.Text="ACCESS GRANTED"

        -- Flash verde en borde y botón
        tween(KBtn,{BackgroundColor3=C.green},0.25)
        tween(KFst,{Color=C.green,Transparency=0},0.25)
        tween(KAcc,{BackgroundColor3=C.green},0.25)
        task.wait(0.5)

        -- Todo el panel desaparece JUNTO: escala hacia el centro + fade en un solo tween
        -- Usamos un wrapper para la escala
        KF.AnchorPoint=Vector2.new(0.5,0.5)
        KF.Position=UDim2.new(0.5,0,0.5,0)

        local fadeT=0.38
        tween(KF,  {Size=UDim2.new(0,0,0,0), BackgroundTransparency=1},  fadeT, Enum.EasingStyle.Quint, Enum.EasingDirection.In)
        tween(KFst,{Transparency=1},                                       fadeT, Enum.EasingStyle.Quint, Enum.EasingDirection.In)
        tween(KBG, {BackgroundTransparency=1},                             fadeT, Enum.EasingStyle.Quint, Enum.EasingDirection.In)

        task.wait(fadeT+0.05)
        KGui:Destroy()
        _G.__WDGKeyPassed=true

    elseif result=="bound" then
        -- Key already used by someone else
        KErr.TextColor3=Color3.fromRGB(255,60,60)
        KErr.Text="  This key is already in use by another account."
        tween(KBoxSt,{Color=Color3.fromRGB(255,100,0)},0.1)
        task.wait(1.2); tween(KBoxSt,{Color=C.stroke},0.3)
        -- still count as failed attempt
        if keyAttempts>=MAX_ATTEMPTS then
            task.wait(0.3)
            lp:Kick("\n\n[WDG HUB — ACCESS DENIED]\n\nYou have entered invalid keys too many times.\nThis incident has been logged.\n\nGet your key at the WDG Discord server.")
        end
    else
        -- Completely wrong key
        KErr.TextColor3=Color3.fromRGB(255,60,60)
        if keyAttempts>=MAX_ATTEMPTS then
            KErr.Text="  Too many failed attempts."
            task.wait(0.5)
            lp:Kick("\n\n[WDG HUB — ACCESS DENIED]\n\nYou have entered an invalid key too many times.\nThis incident has been logged.\n\nGet your key at the WDG Discord server.")
        else
            KErr.Text="  Invalid key. "..tostring(MAX_ATTEMPTS-keyAttempts).." attempt(s) remaining."
            local origPos=KBoxBG.Position
            task.spawn(function()
                for i=1,4 do
                    tween(KBoxBG,{Position=UDim2.new(origPos.X.Scale,origPos.X.Offset+(i%2==0 and 6 or -6),origPos.Y.Scale,origPos.Y.Offset)},0.04)
                    task.wait(0.05)
                end
                KBoxBG.Position=origPos
            end)
            tween(KBoxSt,{Color=Color3.fromRGB(255,60,60)},0.1)
            task.wait(1); tween(KBoxSt,{Color=C.stroke},0.3)
        end
    end
end

