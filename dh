        for _,p in pairs(PLS:GetPlayers()) do if p~=lp and p.Character then local head=p.Character:FindFirstChild("Head"); if head then local pos2D,onScreen=cam:WorldToViewportPoint(head.Position); if onScreen and pos2D.Z>0 then local d=(Vector2.new(pos2D.X,pos2D.Y)-ctr).Magnitude; if d<bestD and d<SL.aimbotDist then bestD=d; best=head end end end end end
        if best then local st=tick(); local c2; c2=RS.RenderStepped:Connect(function() if tick()-st>=lockTime or not T.aimbot or not best or not best.Parent then c2:Disconnect(); locking=false; return end; cam.CFrame=CFrame.new(cam.CFrame.Position,best.Position) end)
        else locking=false; notifyWarn("No target in range") end
