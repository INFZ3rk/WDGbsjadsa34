local MIN_W, MIN_H = 460, 340
RH.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        resizing = true; resizeStart = Vector2.new(input.Position.X, input.Position.Y); startSize = MF.Size
    end
end)
