-- Key→UserId binding stored in _G so it persists across the game session
-- Format: _G.__WDGKeyOwners = { ["KEY"] = userId }
if not _G.__WDGKeyOwners then _G.__WDGKeyOwners = {} end

local function isValidKey(k)
    local trimmed = k:match("^%s*(.-)%s*$"):upper()
    for _, v in ipairs(VALID_KEYS) do
        if v:upper() == trimmed then
            -- Check if this key is already bound to a different user
            local owner = _G.__WDGKeyOwners[trimmed]
            if owner == nil then
                return true, trimmed       -- key free, allow and bind
            elseif owner == lp.UserId then
                return true, trimmed       -- same account, allow
            else
                return false, "bound"      -- bound to another account
            end
        end
    end
    return false, "invalid"
end

