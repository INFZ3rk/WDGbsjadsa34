local dragging = false; local dragStart = Vector2.new(); local startPos = UDim2.new()
TB.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        if input.Position.X > TB.AbsolutePosition.X + TB.AbsoluteSize.X - 124 then return end
        dragging = true; dragStart = Vector2.new(input.Position.X, input.Position.Y); startPos = MF.Position
    end
end)
TB.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end end)
UIS.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = Vector2.new(input.Position.X, input.Position.Y) - dragStart
        MF.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

