--[[
    tog(parent, label, stateKey, onCB, offCB, keyLabel)
    keyLabel: optional string like "Q" or "Z" shown as a key badge
    NOTA: Las notificaciones SOLO se muestran al pulsar el pill ON/OFF,
          NO cuando se activa/desactiva via keybind.
]]
local function tog(parent, label, stateKey, onCB, offCB, keyLabel)
    local row = Instance.new("Frame", parent)
    row.Size = UDim2.new(1, 0, 0, 42); row.BackgroundColor3 = Color3.fromRGB(15, 4, 4)
    row.BorderSizePixel = 0; row.ZIndex = 3
    Instance.new("UICorner", row).CornerRadius = UDim.new(0, 8)
    local rs = Instance.new("UIStroke", row); rs.Color = Color3.fromRGB(35, 10, 10); rs.Thickness = 1; rs.Transparency = 0.4

    -- label
    local lb = Instance.new("TextLabel", row)
    lb.BackgroundTransparency = 1
    lb.Font = Enum.Font.Gotham; lb.TextSize = 12.5
    lb.TextColor3 = C.light; lb.TextXAlignment = Enum.TextXAlignment.Left; lb.ZIndex = 4

    -- toggle pill
    local pill = Instance.new("TextButton", row)
    pill.Size = UDim2.new(0, 54, 0, 26); pill.Position = UDim2.new(1, -62, 0.5, -13)
    pill.BackgroundColor3 = Color3.fromRGB(32, 8, 8); pill.Text = "OFF"
    pill.Font = Enum.Font.GothamBold; pill.TextSize = 11
    pill.TextColor3 = Color3.fromRGB(100, 40, 40); pill.BorderSizePixel = 0; pill.ZIndex = 4
    Instance.new("UICorner", pill).CornerRadius = UDim.new(0, 6)

    if keyLabel then
        lb.Size = UDim2.new(1, -160, 1, 0); lb.Position = UDim2.new(0, 10, 0, 0)
        lb.Text = label
        local kb = Instance.new("Frame", row)
        kb.Size = UDim2.new(0, 36, 0, 24); kb.Position = UDim2.new(1, -104, 0.5, -12)
        kb.BackgroundColor3 = Color3.fromRGB(22, 5, 5); kb.BorderSizePixel = 0; kb.ZIndex = 4
        Instance.new("UICorner", kb).CornerRadius = UDim.new(0, 5)
        local kbSt = Instance.new("UIStroke", kb); kbSt.Color = C.red1; kbSt.Thickness = 1.2; kbSt.Transparency = 0.3
        local kl = Instance.new("TextLabel", kb)
        kl.Size = UDim2.new(1, 0, 1, 0); kl.BackgroundTransparency = 1
        kl.Text = keyLabel; kl.Font = Enum.Font.GothamBold; kl.TextSize = 12
        kl.TextColor3 = C.red1; kl.TextXAlignment = Enum.TextXAlignment.Center; kl.ZIndex = 5
    else
        lb.Size = UDim2.new(1, -80, 1, 0); lb.Position = UDim2.new(0, 10, 0, 0)
        lb.Text = label
    end

    local state = false

    -- setState con flag: showNotif controla si se muestra la notif
    -- Si showNotif es false (por keybind), solo cambia el estado visual, sin notify
    local function setState(v, showNotif)
        state = v
        if showNotif == nil then showNotif = true end  -- default: true (pill click siempre notifica)
        if stateKey then T[stateKey] = v end
        if v then
            tween(pill, {BackgroundColor3 = C.red1, TextColor3 = C.white}, 0.13); pill.Text = "ON"
            if onCB then onCB(showNotif) end
        else
            tween(pill, {BackgroundColor3 = Color3.fromRGB(32, 8, 8), TextColor3 = Color3.fromRGB(100, 40, 40)}, 0.13); pill.Text = "OFF"
            if offCB then offCB(showNotif) end
        end
    end

    -- Pill click: SIEMPRE muestra notificación
    pill.MouseButton1Click:Connect(function() setState(not state, true) end)

    if stateKey then
        togRefs[stateKey] = {setState = setState, getState = function() return state end}
    end
    return row, setState
end

