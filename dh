table.insert(conns,RS.RenderStepped:Connect(function()
    local char=getChar(); if not char then return end
    local hum=char:FindFirstChild("Humanoid")
    if T.speed   and hum then hum.WalkSpeed=SL.walkSpeed end
    if T.infJump and hum then hum.JumpPower=SL.jumpPower end
    if T.infJump and UIS:IsKeyDown(Enum.KeyCode.Space) then if hum then hum:ChangeState(Enum.HumanoidStateType.Jumping) end end
    if T.autoBhop and hum then if hum.FloorMaterial~=Enum.Material.Air then hum:ChangeState(Enum.HumanoidStateType.Jumping) end end
    if T.noclip then for _,p in pairs(char:GetDescendants()) do if p:IsA("BasePart") then pcall(function() p.CanCollide=false end) end end end
    -- ESP
    for _,p in pairs(PLS:GetPlayers()) do
        if p==lp then continue end
        if not T.espBox then
            if espBoxObj[p] then pcall(function() if espBoxObj[p].box then espBoxObj[p].box.Visible=false end end); pcall(function() if espBoxObj[p].nameL then espBoxObj[p].nameL.Visible=false end end); espBoxObj[p]=nil end; continue
        end
        if not p.Character or not p.Character:FindFirstChild("HumanoidRootPart") then
            if espBoxObj[p] then pcall(function() if espBoxObj[p].box then espBoxObj[p].box.Visible=false end end); pcall(function() if espBoxObj[p].nameL then espBoxObj[p].nameL.Visible=false end end); espBoxObj[p]=nil end; continue
        end
        if not espBoxObj[p] then
            local ok1,box=pcall(function() return Drawing.new("Square") end); local ok2,nameL=pcall(function() return Drawing.new("Text") end)
            espBoxObj[p]={box=ok1 and box or nil,nameL=ok2 and nameL or nil}
            if ok1 then box.Thickness=1.5; box.Color=Color3.fromRGB(220,50,50); box.Filled=false; box.Visible=false end
            if ok2 then nameL.Size=13; nameL.Color=Color3.fromRGB(255,160,160); nameL.Outline=true; nameL.Text=p.Name; nameL.Visible=false end
        end
        local head=p.Character:FindFirstChild("Head"); if not head then continue end
        local pos2D,onScreen=cam:WorldToViewportPoint(head.Position)
        if onScreen and pos2D.Z>0 then
            local dist=(cam.CFrame.Position-head.Position).Magnitude
            local sc=math.clamp(1600/dist,14,120); local bx=pos2D.X-sc*0.5; local by=pos2D.Y-sc*0.8
            if espBoxObj[p].box   then espBoxObj[p].box.Position=Vector2.new(bx,by);   espBoxObj[p].box.Size=Vector2.new(sc,sc*2); espBoxObj[p].box.Visible=true end
            if espBoxObj[p].nameL then espBoxObj[p].nameL.Position=Vector2.new(bx,by-18); espBoxObj[p].nameL.Visible=true end
        else
            if espBoxObj[p].box   then espBoxObj[p].box.Visible=false end
            if espBoxObj[p].nameL then espBoxObj[p].nameL.Visible=false end
        end
    end
end))

