local function mkTab(name)
    if tabF[name] then return tabF[name] end
    local f = Instance.new("Frame", Scroll)
    f.Size = UDim2.new(1, 0, 1, 0); f.BackgroundTransparency = 1; f.Visible = false; f.ZIndex = 2
    local lay = Instance.new("UIListLayout", f)
    lay.Padding = UDim.new(0, 6); lay.HorizontalAlignment = Enum.HorizontalAlignment.Center
    lay.SortOrder = Enum.SortOrder.LayoutOrder
    local pad = Instance.new("UIPadding", f)
    pad.PaddingTop = UDim.new(0, 8); pad.PaddingLeft = UDim.new(0, 8)
    pad.PaddingRight = UDim.new(0, 8); pad.PaddingBottom = UDim.new(0, 14)
    tabF[name] = f; return f
end

local function refreshCanvas(name)
    local f = tabF[name]; if not f then return end
    local lay = f:FindFirstChildOfClass("UIListLayout")
    if lay then Scroll.CanvasSize = UDim2.new(0, 0, 0, lay.AbsoluteContentSize.Y + 26) end
end

local function switchTab(name)
    curTab = name; SecT.Text = name
    for n, f in pairs(tabF) do f.Visible = (n == name) end
    for n, b in pairs(tabB) do
        local a = (n == name)
        tween(b, {BackgroundColor3 = a and C.red1 or Color3.fromRGB(18, 5, 5),
                  TextColor3       = a and C.black or C.light}, 0.13)
    end
    Scroll.CanvasPosition = Vector2.new(0, 0)
    task.wait(); refreshCanvas(name)
end

