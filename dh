end

--[[
    notify(msg, col, title, icon)
    col  : accent Color3  (default red1)
    title: string         (default "WDG HUB")
    icon : emoji string   (default "🩸")
]]
local function notify(msg, col, title, icon)
    col   = col   or C.red1
    title = title or "WDG HUB"
    icon  = icon  or "🩸"

    -- ── outer frame ──────────────────────────────────────────────
    local fr = Instance.new("Frame")
    fr.Size                 = UDim2.new(0, N_W, 0, N_H)
    fr.Position             = UDim2.new(1, N_W + 30, 0, 18)
    fr.BackgroundColor3     = Color3.fromRGB(8, 2, 2)
    fr.BackgroundTransparency = 0.04
    fr.BorderSizePixel      = 0
    fr.ClipsDescendants     = false
    fr.Parent               = NotifGui
    Instance.new("UICorner", fr).CornerRadius = UDim.new(0, 13)

    -- glowing outer border
    local outerGlow = Instance.new("UIStroke", fr)
    outerGlow.Color       = col
    outerGlow.Thickness   = 1.6
    outerGlow.Transparency = 0.15
    outerGlow.ApplyStrokeMode = Enum.ApplyStrokeMode.Border

    -- left accent stripe (redondeada)
    local stripe = Instance.new("Frame", fr)
    stripe.Size             = UDim2.new(0, 4, 1, -16)
    stripe.Position         = UDim2.new(0, 6, 0, 8)
    stripe.BackgroundColor3 = col
    stripe.BorderSizePixel  = 0
    Instance.new("UICorner", stripe).CornerRadius = UDim.new(1, 0)

    -- icon circle background
    local iconBg = Instance.new("Frame", fr)
    iconBg.Size             = UDim2.new(0, 40, 0, 40)
    iconBg.Position         = UDim2.new(0, 16, 0.5, -20)
    iconBg.BackgroundColor3 = col
    iconBg.BackgroundTransparency = 0.75
    iconBg.BorderSizePixel  = 0
    Instance.new("UICorner", iconBg).CornerRadius = UDim.new(0, 10)
    local iconRing = Instance.new("UIStroke", iconBg)
    iconRing.Color       = col
    iconRing.Thickness   = 1.2
    iconRing.Transparency = 0.35

    -- icon emoji
    local iconLbl = Instance.new("TextLabel", iconBg)
    iconLbl.Size               = UDim2.new(1, 0, 1, 0)
    iconLbl.BackgroundTransparency = 1
    iconLbl.Text               = icon
    iconLbl.Font               = Enum.Font.GothamBold
    iconLbl.TextSize           = 20
    iconLbl.TextColor3         = col
    iconLbl.TextXAlignment     = Enum.TextXAlignment.Center
    iconLbl.ZIndex             = 4

    -- title label
    local tl = Instance.new("TextLabel", fr)
    tl.Size               = UDim2.new(1, -68, 0, 16)
    tl.Position           = UDim2.new(0, 64, 0, 14)
    tl.BackgroundTransparency = 1
    tl.Text               = title
    tl.Font               = Enum.Font.GothamBold
    tl.TextSize           = 10
    tl.TextColor3         = col
    tl.TextXAlignment     = Enum.TextXAlignment.Left
    tl.ZIndex             = 4
    tl.TextTransparency   = 0.05

    -- message label
    local lb = Instance.new("TextLabel", fr)
    lb.Size               = UDim2.new(1, -68, 0, 38)
    lb.Position           = UDim2.new(0, 64, 0, 30)
    lb.BackgroundTransparency = 1
    lb.Text               = msg
    lb.Font               = Enum.Font.Gotham
    lb.TextSize           = 12
    lb.TextColor3         = Color3.fromRGB(225, 180, 180)
    lb.TextXAlignment     = Enum.TextXAlignment.Left
    lb.TextWrapped        = true
    lb.ZIndex             = 4

    -- progress bar track
    local track = Instance.new("Frame", fr)
    track.Size             = UDim2.new(1, -8, 0, 3)
    track.Position         = UDim2.new(0, 4, 1, -6)
    track.BackgroundColor3 = Color3.fromRGB(30, 6, 6)
    track.BorderSizePixel  = 0
    Instance.new("UICorner", track).CornerRadius = UDim.new(0, 3)

    -- progress bar fill
    local bar = Instance.new("Frame", track)
    bar.Size             = UDim2.new(1, 0, 1, 0)
    bar.BackgroundColor3 = col
    bar.BorderSizePixel  = 0
    Instance.new("UICorner", bar).CornerRadius = UDim.new(0, 3)

    -- progress bar glow (overlay, same color, semi-transparent, slightly narrower)
    local barGlow = Instance.new("Frame", track)
    barGlow.Size             = UDim2.new(1, 0, 0.5, 0)
    barGlow.Position         = UDim2.new(0, 0, 0, 0)
    barGlow.BackgroundColor3 = C.white
    barGlow.BackgroundTransparency = 0.78
    barGlow.BorderSizePixel  = 0
    barGlow.ZIndex           = 2
    Instance.new("UICorner", barGlow).CornerRadius = UDim.new(0, 3)

    -- ── animate in ───────────────────────────────────────────────
    table.insert(notifList, fr)
    tween(fr, {Position = UDim2.new(1, -N_W - 16, 0, 18)}, 0.38,
        Enum.EasingStyle.Back, Enum.EasingDirection.Out)
    rebuildPos()

    -- pulse border once
    task.spawn(function()
        task.wait(0.1)
        tween(outerGlow, {Transparency = 0}, 0.12)
        task.wait(0.14)
        tween(outerGlow, {Transparency = 0.15}, 0.3)
    end)

    -- countdown + dismiss
    task.spawn(function()
        local dur = 4.2; local steps = 120
        for i = steps, 0, -1 do
            if not bar.Parent then return end
            bar.Size     = UDim2.new(i / steps, 0, 1, 0)
            barGlow.Size = UDim2.new(i / steps, 0, 0.5, 0)
            task.wait(dur / steps)
        end
        -- fade out
        tween(fr,       {BackgroundTransparency = 1}, 0.28)
        tween(outerGlow,{Transparency = 1},           0.28)
        tween(lb,       {TextTransparency = 1},       0.22)
        tween(tl,       {TextTransparency = 1},       0.22)
        tween(iconLbl,  {TextTransparency = 1},       0.22)
        tween(stripe,   {BackgroundTransparency = 1}, 0.22)
        tween(iconBg,   {BackgroundTransparency = 1}, 0.22)
        -- slide right
        tween(fr, {
            Position = UDim2.new(1, N_W + 30, 0,
                fr.AbsolutePosition.Y
                - (NotifGui.AbsolutePosition and NotifGui.AbsolutePosition.Y or 0))
        }, 0.30, Enum.EasingStyle.Quint, Enum.EasingDirection.In)
        task.wait(0.34)
        for i2, f2 in ipairs(notifList) do
            if f2 == fr then table.remove(notifList, i2); break end
        end
        fr:Destroy(); rebuildPos()
    end)
end

