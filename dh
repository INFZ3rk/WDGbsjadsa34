local particleConnsKey={}
local function spawnKeyParticle()
    local dot=Instance.new("Frame",KBG)
    local sz=math.random(2,5)
    dot.Size=UDim2.new(0,sz,0,sz)
    local vp=cam.ViewportSize
    local cx=math.random(0,math.floor(vp.X)); local cy=math.random(0,math.floor(vp.Y*0.5))
    dot.Position=UDim2.new(0,cx,0,cy)
    dot.BackgroundColor3=C.red1; dot.BackgroundTransparency=math.random(45,65)/100
    dot.BorderSizePixel=0; dot.ZIndex=1; Instance.new("UICorner",dot).CornerRadius=UDim.new(1,0)
    local vy=math.random(30,70); local vx=math.random(-15,8)
    local life=0; local maxLife=(vp.Y/vy)*math.random(90,110)/100
    local conn
    conn=RS.Heartbeat:Connect(function(dt)
        if not dot.Parent then conn:Disconnect(); return end
        life=life+dt; cx=cx+vx*dt; cy=cy+vy*dt
        dot.Position=UDim2.new(0,cx,0,cy)
        local prog=life/maxLife
        if prog>=0.6 then dot.BackgroundTransparency=math.min(1,(prog-0.6)/0.4) end
        if cy>vp.Y+10 or life>=maxLife then conn:Disconnect(); pcall(function() dot:Destroy() end) end
    end)
    table.insert(particleConnsKey,conn)
end
