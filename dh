-- ================================================================
--  SEND CHAT
-- ================================================================
local function sendChat(msg)
    local sent=false
    pcall(function()
        local tcs=game:GetService("TextChatService")
        local ch=tcs.TextChannels:FindFirstChild("RBXGeneral") or tcs.TextChannels:FindFirstChildOfClass("TextChannel")
        if ch then ch:SendAsync(msg); sent=true end
    end)
    if sent then return end
    pcall(function()
        game:GetService("ReplicatedStorage").DefaultChatSystemChatEvents.SayMessageRequest:FireServer(msg,"All"); sent=true
    end)
    if sent then return end
    pcall(function()
        local char=getChar(); if char then game:GetService("Chat"):Chat(char,msg,Enum.ChatColor.Red) end
    end)
end

