        local delta = Vector2.new(input.Position.X, input.Position.Y) - resizeStart
        MF.Size = UDim2.new(0, math.max(MIN_W, startSize.X.Offset + delta.X), 0, math.max(MIN_H, startSize.Y.Offset + delta.Y))
    end
end)

